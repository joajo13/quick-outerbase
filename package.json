{
  "name": "quick-outerbase",
  "version": "0.5.0",
  "private": true,
  "description": "Database GUI in your terminal: pass a DATABASE_URL and `npx quick-outerbase` opens a local web UI to browse, query and edit Postgres, MySQL, SQLite, libSQL/Turso and DynamoDB. Open-source Prisma Studio / Drizzle Studio / TablePlus / DbGate alternative. Unofficial community fork of Outerbase Studio (AGPL-3.0).",
  "license": "AGPL-3.0-only",
  "keywords": [
    "database",
    "database-gui",
    "database-client",
    "sql-client",
    "prisma-studio-alternative",
    "drizzle-studio-alternative",
    "tableplus-alternative",
    "dbgate-alternative",
    "outerbase-studio",
    "erd-viewer",
    "postgres",
    "mysql",
    "sqlite",
    "libsql",
    "turso",
    "dynamodb"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joajo13/quick-outerbase.git"
  },
  "homepage": "https://github.com/joajo13/quick-outerbase#readme",
  "bugs": {
    "url": "https://github.com/joajo13/quick-outerbase/issues"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev -p 3008",
    "dev-https": "next dev --experimental-https",
    "start": "next start",
    "build": "next build",
    "build:local": "node bin/prepare-build.mjs --force",
    "prepare": "node bin/prepare-build.mjs",
    "tsc": "tsc --noEmit --skipLibCheck",
    "test": "jest",
    "audit:gate": "node scripts/audit-gate.mjs",
    "staged": "npm run typecheck && npm run lint && jest",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "format": "prettier --check .",
    "lint": "next lint",
    "dialect": "node build-dialect.js",
    "studio": "node bin/fork-studio.mjs",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "bin": {
    "quick-outerbase": "bin/fork-studio.mjs",
    "fork-studio": "bin/fork-studio.mjs"
  },
  "files": [
    "bin",
    "src",
    "public",
    "next.config.js",
    "tsconfig.json",
    "postcss.config.cjs",
    "components.json",
    "build-dialect.js",
    ".eslintrc.json",
    "LICENSE",
    "AVISO_LICENCIA.md"
  ],
  "overrides": {
    "@libsql/client": "^0.5.3"
  },
